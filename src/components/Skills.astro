---
import { skillGroups } from "../data/site";
---

<section id="skills" class="mx-auto max-w-5xl px-6 py-24">
  <div class="reveal mb-12">
    <p class="font-mono text-sm text-[var(--color-peach-strong)]">03 · Toolkit</p>
    <h2
      class="mt-2 font-display text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      Skills & technologies
    </h2>
  </div>

  <div class="grid gap-px overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-border)] sm:grid-cols-2 lg:grid-cols-3">
    {
      skillGroups.map((group) => (
        <div class="reveal bg-[var(--color-surface)] p-6">
          <h3 class="font-display text-sm font-bold uppercase tracking-wider text-[var(--color-accent)]">
            {group.label}
          </h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-md bg-[var(--color-surface-2)] px-2.5 py-1 text-sm text-[var(--color-ink)]/90">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
