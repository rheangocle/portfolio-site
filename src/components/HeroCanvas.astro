---
// Interactive hero motion: skill/tech bubbles grouped into colored clusters by
// category. Bubbles gently bob, settle toward their group, and dodge the
// cursor. Cosmetic + aria-hidden; renders a single static frame under
// prefers-reduced-motion.
---

<canvas
  id="hero-canvas"
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 z-0 h-full w-full"
></canvas>

<script>
  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  // Cancel any loop left running by a previous script execution (e.g. dev HMR).
  const wglobal = window as unknown as { __heroRaf?: number };
  if (wglobal.__heroRaf) cancelAnimationFrame(wglobal.__heroRaf);

  if (canvas && ctx) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const parent = canvas.parentElement as HTMLElement;

    // Peach-to-lavender palette: clusters span the two theme accents.
    // Anchors avoid the vertical center band where the headline sits.
    const CATS = {
      lang: { color: "123, 103, 207", anchor: [0.3, 0.14] }, // lavender
      framework: { color: "159, 118, 196", anchor: [0.68, 0.66] }, // lavender-mauve
      cms: { color: "197, 130, 175", anchor: [0.26, 0.82] }, // mauve
      infra: { color: "239, 158, 114", anchor: [0.84, 0.82] }, // peach
      db: { color: "230, 146, 142", anchor: [0.82, 0.12] }, // rose-peach
    } as const;

    const SKILLS: { label: string; cat: keyof typeof CATS }[] = [
      { label: "TypeScript", cat: "lang" },
      { label: "Python", cat: "lang" },
      { label: "PHP", cat: "lang" },
      { label: "React", cat: "framework" },
      { label: "Vue", cat: "framework" },
      { label: "Laravel", cat: "framework" },
      { label: "Astro", cat: "framework" },
      { label: "WordPress", cat: "cms" },
      { label: "Elementor", cat: "cms" },
      { label: "Docker", cat: "infra" },
      { label: "Linux", cat: "infra" },
      { label: "CI/CD", cat: "infra" },
      { label: "PostgreSQL", cat: "db" },
      { label: "Redis", cat: "db" },
    ];

    type Bubble = {
      x: number; y: number; vx: number; vy: number; r: number;
      label: string; color: string; ax: number; ay: number; phase: number;
    };

    let W = 0;
    let H = 0;
    let bubbles: Bubble[] = [];
    const mouse = { x: -9999, y: -9999, active: false };

    function build() {
      W = parent.clientWidth;
      H = parent.clientHeight;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.round(W * dpr);
      canvas!.height = Math.round(H * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

      const mobile = W < 768;
      const region = {
        x0: mobile ? W * 0.06 : W * 0.54,
        x1: mobile ? W * 0.94 : W * 0.97,
        y0: H * 0.1,
        y1: H * 0.95,
      };
      const rw = region.x1 - region.x0;
      const rh = region.y1 - region.y0;
      const scale = mobile ? 0.8 : 1;

      ctx!.font = `600 ${12 * scale}px Inter, ui-sans-serif, system-ui, sans-serif`;
      bubbles = SKILLS.map((s) => {
        const cat = CATS[s.cat];
        const ax = region.x0 + cat.anchor[0] * rw;
        const ay = region.y0 + cat.anchor[1] * rh;
        const r = Math.max(20 * scale, ctx!.measureText(s.label).width / 2 + 14 * scale);
        return {
          x: ax + (Math.random() - 0.5) * 40,
          y: ay + (Math.random() - 0.5) * 40,
          vx: 0, vy: 0, r, ax, ay,
          label: s.label,
          color: cat.color,
          phase: Math.random() * Math.PI * 2,
        };
      });
    }

    function physics(dt: number, t: number) {
      const damp = Math.exp(-2.6 * dt);
      for (const b of bubbles) {
        // Gentle pull toward the category anchor.
        let fx = (b.ax - b.x) * 1.4;
        let fy = (b.ay - b.y) * 1.4;
        // Cursor repulsion.
        if (mouse.active) {
          const dx = b.x - mouse.x;
          const dy = b.y - mouse.y;
          const d = Math.hypot(dx, dy);
          const reach = b.r + 80;
          if (d < reach && d > 0.01) {
            const push = ((reach - d) / reach) * 900;
            fx += (dx / d) * push;
            fy += (dy / d) * push;
          }
        }
        b.vx = (b.vx + fx * dt) * damp;
        b.vy = (b.vy + fy * dt) * damp;
        b.x += b.vx * dt;
        b.y += b.vy * dt;
      }
      // Soft collision separation.
      for (let i = 0; i < bubbles.length; i++) {
        for (let j = i + 1; j < bubbles.length; j++) {
          const a = bubbles[i];
          const c = bubbles[j];
          const dx = c.x - a.x;
          const dy = c.y - a.y;
          const d = Math.hypot(dx, dy) || 0.01;
          const min = a.r + c.r + 6;
          if (d < min) {
            const o = (min - d) / 2;
            const ux = dx / d;
            const uy = dy / d;
            a.x -= ux * o; a.y -= uy * o;
            c.x += ux * o; c.y += uy * o;
          }
        }
      }
    }

    function draw(t: number) {
      ctx!.clearRect(0, 0, W, H);
      ctx!.textAlign = "center";
      ctx!.textBaseline = "middle";
      const mobile = W < 768;
      ctx!.font = `600 ${mobile ? 9.6 : 12}px Inter, ui-sans-serif, system-ui, sans-serif`;
      for (const b of bubbles) {
        const bob = Math.sin(t * 0.0009 + b.phase) * 3;
        const y = b.y + bob;
        ctx!.beginPath();
        ctx!.arc(b.x, y, b.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${b.color}, 0.12)`;
        ctx!.fill();
        ctx!.lineWidth = 1.2;
        ctx!.strokeStyle = `rgba(${b.color}, 0.5)`;
        ctx!.stroke();
        ctx!.fillStyle = "rgba(40, 34, 60, 0.92)";
        ctx!.fillText(b.label, b.x, y);
      }
    }

    build();
    // Settle a few steps so the first paint is already clustered, not scattered.
    for (let i = 0; i < 60; i++) physics(1 / 60, 0);
    draw(0);

    window.addEventListener("resize", () => {
      build();
      for (let i = 0; i < 60; i++) physics(1 / 60, 0);
      draw(0);
    });

    if (!reduce) {
      window.addEventListener("pointermove", (e) => {
        const rect = canvas!.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
        mouse.active = mouse.x >= 0 && mouse.x <= W && mouse.y >= 0 && mouse.y <= H;
      });
      window.addEventListener("pointerleave", () => (mouse.active = false));
      window.addEventListener("blur", () => (mouse.active = false));

      let running = false;
      let last = 0;
      function frame(t: number) {
        if (!running) {
          wglobal.__heroRaf = undefined;
          return;
        }
        const dt = last ? Math.min((t - last) / 1000, 0.05) : 1 / 60;
        last = t;
        physics(dt, t);
        draw(t);
        wglobal.__heroRaf = requestAnimationFrame(frame);
      }
      function start() {
        if (running) return;
        running = true;
        last = 0;
        wglobal.__heroRaf = requestAnimationFrame(frame);
      }
      function stop() {
        running = false;
      }

      const io = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting && !document.hidden) start();
          else stop();
        },
        { threshold: 0 }
      );
      io.observe(canvas);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stop();
        else start();
      });
      start();
    }
  }
</script>
