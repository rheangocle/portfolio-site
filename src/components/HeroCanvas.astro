---
// Subtle decorative hero motion: a slow-drifting constellation of project
// nodes connected by faint lines. Purely cosmetic, aria-hidden, and disabled
// (rendered as a single static frame) for users who prefer reduced motion.
---

<canvas
  id="hero-canvas"
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 z-0 h-full w-full"
></canvas>

<script>
  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  // Cancel any loop left running by a previous script execution (e.g. dev HMR),
  // so animation frames can never stack up and speed the motion up.
  const w = window as unknown as { __heroRaf?: number };
  if (w.__heroRaf) cancelAnimationFrame(w.__heroRaf);

  if (canvas && ctx) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const parent = canvas.parentElement as HTMLElement;
    const ACCENT = "109, 91, 208"; // matches --color-accent (#6d5bd0)
    const PROJECTS = ["BellyEase", "ClothingCue", "Helm", "WFSU", "Guidepoint", "Down Unda"];
    const SPEED = 7; // px per second — deliberately gentle

    type Node = { x: number; y: number; vx: number; vy: number; r: number; label?: string };

    let W = 0;
    let H = 0;
    let region = { x0: 0, x1: 0, y0: 0, y1: 0 };
    let nodes: Node[] = [];
    let LINK = 180;

    const rand = (a: number, b: number) => a + Math.random() * (b - a);

    function build() {
      W = parent.clientWidth;
      H = parent.clientHeight;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.round(W * dpr);
      canvas!.height = Math.round(H * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

      const mobile = W < 768;
      // Keep the field to the right of the headline on desktop; centered on mobile.
      region = {
        x0: mobile ? W * 0.08 : W * 0.5,
        x1: mobile ? W * 0.92 : W * 0.95,
        y0: H * 0.16,
        y1: H * 0.9,
      };
      LINK = Math.min(W, H) * (mobile ? 0.42 : 0.3);

      const labels = mobile ? PROJECTS.slice(0, 4) : PROJECTS;
      const fillers = mobile ? 3 : 6;
      const make = (label?: string): Node => ({
        x: rand(region.x0, region.x1),
        y: rand(region.y0, region.y1),
        vx: rand(-SPEED, SPEED),
        vy: rand(-SPEED, SPEED),
        r: label ? 3 : 1.6,
        label,
      });
      nodes = [...labels.map((l) => make(l)), ...Array.from({ length: fillers }, () => make())];
    }

    let px = 0;
    let py = 0;
    let tpx = 0;
    let tpy = 0;

    function draw() {
      ctx!.clearRect(0, 0, W, H);
      px += (tpx - px) * 0.05;
      py += (tpy - py) * 0.05;
      ctx!.save();
      ctx!.translate(px, py);

      // Connecting lines (drawn first so nodes sit on top).
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const d = Math.hypot(dx, dy);
          if (d < LINK) {
            ctx!.strokeStyle = `rgba(${ACCENT}, ${(1 - d / LINK) * 0.16})`;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(nodes[i].x, nodes[i].y);
            ctx!.lineTo(nodes[j].x, nodes[j].y);
            ctx!.stroke();
          }
        }
      }

      // Nodes + labels.
      ctx!.font = "600 12px Inter, ui-sans-serif, system-ui, sans-serif";
      ctx!.textBaseline = "middle";
      for (const n of nodes) {
        ctx!.fillStyle = `rgba(${ACCENT}, ${n.label ? 0.85 : 0.5})`;
        ctx!.beginPath();
        ctx!.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx!.fill();
        if (n.label) {
          ctx!.fillStyle = `rgba(${ACCENT}, 0.55)`;
          ctx!.fillText(n.label, n.x + 9, n.y);
        }
      }
      ctx!.restore();
    }

    function step(dt: number) {
      for (const n of nodes) {
        n.x += n.vx * dt;
        n.y += n.vy * dt;
        if (n.x < region.x0 || n.x > region.x1) n.vx *= -1;
        if (n.y < region.y0 || n.y > region.y1) n.vy *= -1;
      }
    }

    build();
    draw();
    window.addEventListener("resize", () => {
      build();
      draw();
    });

    if (!reduce) {
      window.addEventListener("pointermove", (e) => {
        tpx = (e.clientX / window.innerWidth - 0.5) * 18;
        tpy = (e.clientY / window.innerHeight - 0.5) * 18;
      });

      let running = false;
      let last = 0;

      function frame(t: number) {
        if (!running) {
          w.__heroRaf = undefined;
          return;
        }
        // Time-based movement so speed is identical on any refresh rate.
        const dt = last ? Math.min((t - last) / 1000, 0.05) : 0;
        last = t;
        step(dt);
        draw();
        w.__heroRaf = requestAnimationFrame(frame);
      }

      function start() {
        if (running) return; // never stack a second loop
        running = true;
        last = 0;
        w.__heroRaf = requestAnimationFrame(frame);
      }
      function stop() {
        running = false;
      }

      const io = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting && !document.hidden) start();
          else stop();
        },
        { threshold: 0 }
      );
      io.observe(canvas);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stop();
        else start();
      });
      start();
    }
  }
</script>
