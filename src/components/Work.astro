---
import { projects } from "../data/site";
import ProjectCard from "./ProjectCard.astro";

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section id="work" class="mx-auto max-w-5xl px-6 py-24">
  <div class="reveal mb-12">
    <p class="font-mono text-sm text-[var(--color-peach-strong)]">01 · Selected work</p>
    <h2
      class="mt-2 font-display text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      Things I've built and shipped
    </h2>
    <p class="mt-3 max-w-2xl text-[var(--color-muted)]">
      A mix of product ownership and enterprise delivery: full-stack apps,
      large-scale CMS work, and internal platforms.
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {featured.map((project) => <ProjectCard project={project} />)}
  </div>

  {
    rest.length > 0 && (
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        {rest.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )
  }
</section>
