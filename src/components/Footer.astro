---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)]">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-3 px-6 py-8 text-sm text-[var(--color-muted)] sm:flex-row"
  >
    <p>© {year} {site.name}</p>
    <p>Built with Astro &amp; Tailwind · {site.location}</p>
  </div>
</footer>
